{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default capabilities for main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/node",
          "sidecar": true,
          "args": [
            { "validator": ".+" },
            "--port",
            { "validator": "\\d+" },
            "--data-dir",
            { "validator": ".+" }
          ]
        }
      ]
    }
  ]
}
