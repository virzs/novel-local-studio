{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Novel Local Studio",
  "version": "0.0.0",
  "identifier": "studio.novel.local",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Novel Local Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "resources/mastra/**/*"
    ],
    "externalBin": [
      "binaries/node"
    ]
  }
}
