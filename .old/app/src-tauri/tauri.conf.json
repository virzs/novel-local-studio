{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Novel Local Studio",
  "version": "0.1.0",
  "identifier": "com.opencodestudio.novel-local-studio",
  "build": {
    "beforeDevCommand": "pnpm -C .. run dev:services",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/mastra-server"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Novel Local Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
