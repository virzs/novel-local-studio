{
  "name": "@novel-local-studio/mastra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "pkg": "node scripts/bundle.mjs && @yao-pkg/pkg dist-bundle/server.cjs --target node20 --output dist-bin/mastra-server --no-bytecode --public"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@libsql/client": "^0.14.0",
    "@mastra/ai-sdk": "^1.1.7",
    "@mastra/core": "^1.17.0",
    "@mastra/fastembed": "^1.0.1",
    "@mastra/hono": "^1.1.1",
    "@mastra/libsql": "^1.7.2",
    "@mastra/memory": "^1.10.0",
    "ai": "^6.0.141",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.12.9",
    "zod": "^3.25.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "5.15.0",
    "drizzle-kit": "^0.31.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "pkg": {
    "assets": [
      "node_modules/@libsql/linux-x64-gnu/*.node",
      "node_modules/@libsql/darwin-arm64/*.node",
      "node_modules/@libsql/darwin-x64/*.node",
      "node_modules/@libsql/win32-x64-msvc/*.node"
    ],
    "targets": [
      "node20-macos-arm64",
      "node20-macos-x64",
      "node20-linux-x64",
      "node20-win-x64"
    ]
  }
}
